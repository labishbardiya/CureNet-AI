# CureNet OCR Backend — Environment Variables
# Copy this to .env and fill in your keys

PORT=3000

# ─── AI API Keys (Cloud Fallback) ──────────────────────────────
GROQ_API_KEY=your_groq_key_here
TAVILY_API_KEY=your_tavily_key_here

# ─── Bhashini Translation API ─────────────────────────────────
BHASHINI_API_KEY=your_bhashini_key_here
BHASHINI_USER_ID=your_bhashini_user_id_here
BHASHINI_AUTH=your_bhashini_auth_token_here

# ─── ABDM Sandbox Keys ────────────────────────────────────────
ABDM_CLIENT_ID=your_abdm_client_id_here
ABDM_CLIENT_SECRET=your_abdm_client_secret_here

# ─── MongoDB ───────────────────────────────────────────────────
MONGO_URI=your_mongodb_connection_string_here

# ─── Gemma 4 Local Inference (Ollama) ──────────────────────────
# The backend uses Gemma 4 31B Dense for medical entity extraction
# and FHIR R4 conversion via local Ollama inference.
#
# Setup:
#   1. Install Ollama: https://ollama.com/download
#   2. Pull model: ollama pull gemma4:31b
#   3. Start server: ollama serve
#
OLLAMA_URL=http://localhost:11434
GEMMA4_MODEL=gemma4:31b
