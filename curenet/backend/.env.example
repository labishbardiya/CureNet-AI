# CureNet Backend — Environment Variables
# Copy this to .env and fill in your keys

PORT=3000

# ─── MongoDB (Required) ────────────────────────────────────────
# MongoDB Atlas connection string
# Get one free at: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/CureNet?retryWrites=true&w=majority

# ─── AI API Keys (Cloud Fallback) ──────────────────────────────
# Groq Cloud API Key — fallback when Ollama is unavailable
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Tavily Search API Key — web-augmented medical queries (RAG)
# Get one at: https://tavily.com
TAVILY_API_KEY=your_tavily_key_here

# ─── Bhashini Translation API ─────────────────────────────────
# Government of India's NLP service for 22 Indian languages
# Register at: https://bhashini.gov.in/ulca/user/register
BHASHINI_API_KEY=your_bhashini_key_here
BHASHINI_USER_ID=your_bhashini_user_id_here
BHASHINI_AUTH=your_bhashini_auth_token_here

# ─── ABDM Sandbox Keys ────────────────────────────────────────
# Register at: https://sandbox.abdm.gov.in
ABDM_CLIENT_ID=your_abdm_client_id_here
ABDM_CLIENT_SECRET=your_abdm_client_secret_here

# ─── Gemma 4 Local Inference (Ollama) ──────────────────────────
# Optional — used for edge AI when running locally
# Install: https://ollama.com/download
# Pull models: ollama pull gemma4:e4b && ollama pull gemma4:31b
# Start: ollama serve
OLLAMA_URL=http://localhost:11434
GEMMA4_MODEL=gemma4:31b
